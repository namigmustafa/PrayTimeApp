<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Force MAUI's main theme to use MaterialComponents so Material widgets
         (BottomNavigationView, TextAppearance.MaterialComponents.*) resolve on all devices. -->
    <style name="Maui.MainTheme" parent="Theme.MaterialComponents.DayNight.Bridge">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Fixed size for both selected and unselected tab labels -->
    <style name="AppBottomNavText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
    </style>
</resources>
