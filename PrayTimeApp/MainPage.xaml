<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:PrayTimeApp.Extensions"
             x:Class="PrayTimeApp.MainPage"
             BackgroundColor="{StaticResource AppBg}">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,20" Spacing="8">

            <!-- ═══════════════════════════════════════════ -->
            <!--  HEADER  -->
            <!-- ═══════════════════════════════════════════ -->
            <!-- Location row -->
            <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                <Label Text="📍" FontSize="16" TextColor="{StaticResource GoldAccent}"
                       VerticalOptions="Center"/>
                <Label x:Name="LocationLabel"
                       Text="..." FontSize="14" FontAttributes="Bold"
                       TextColor="{StaticResource GoldAccent}"
                       CharacterSpacing="1.2" VerticalOptions="Center"/>
                <!-- Edit city -->
                <Border BackgroundColor="Transparent"
                        StrokeThickness="0"
                        Padding="4,0"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLocationEditTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="✎" FontSize="16"
                           TextColor="{StaticResource GoldAccent}"
                           VerticalOptions="Center"/>
                </Border>
                <!-- Refresh GPS -->
                <Border BackgroundColor="Transparent"
                        StrokeThickness="0"
                        Padding="4,0"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRefreshLocationTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="⟳" FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource GoldAccent}"
                           VerticalOptions="Center"/>
                </Border>
            </HorizontalStackLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!--  DATE CARD  -->
            <!-- ═══════════════════════════════════════════ -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0"
                    Padding="18,14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="4">
                    <Label x:Name="DateLabel"
                           Text="—"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" FontAttributes="Bold"/>
                    <Label x:Name="HijriLabel"
                           Text="—"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"/>
                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  CURRENT PRAYER CARD  -->
            <!-- ═══════════════════════════════════════════ -->
            <Border StrokeThickness="0" Padding="20,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F2218" Offset="0.0"/>
                        <GradientStop Color="#2A3A18" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="8">


                    <!-- Current prayer name -->
                    <Label x:Name="CurrentPrayerName"
                           Text="—"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="40" FontAttributes="Bold"
                           Margin="0,-2,0,0"/>

                    <!-- "NEXT IN" label -->
                    <Label Text="{i18n:Translate NextIn}"
                           TextColor="{StaticResource GreenCardText}"
                           FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1.5"/>

                    <!-- Countdown HH : MM : SS -->
                    <HorizontalStackLayout Spacing="0" VerticalOptions="Center">

                            <VerticalStackLayout Spacing="0">
                                <Label x:Name="HrsLabel" Text="00"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="34" FontAttributes="Bold"
                                       LineBreakMode="NoWrap"/>
                                <Label Text="{i18n:Translate Hrs}"
                                       TextColor="{StaticResource GreenCardText}"
                                       FontSize="10" FontAttributes="Bold"
                                       CharacterSpacing="1"/>
                            </VerticalStackLayout>

                            <Label Text=" : "
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="28" FontAttributes="Bold"
                                   VerticalOptions="Start" Margin="2,0"/>

                            <VerticalStackLayout Spacing="0">
                                <Label x:Name="MinLabel" Text="00"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="34" FontAttributes="Bold"
                                       LineBreakMode="NoWrap"/>
                                <Label Text="{i18n:Translate Min}"
                                       TextColor="{StaticResource GreenCardText}"
                                       FontSize="10" FontAttributes="Bold"
                                       CharacterSpacing="1"/>
                            </VerticalStackLayout>

                            <Label Text=" : "
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="28" FontAttributes="Bold"
                                   VerticalOptions="Start" Margin="2,0"/>

                            <VerticalStackLayout Spacing="0">
                                <Label x:Name="SecLabel" Text="00"
                                       TextColor="{StaticResource GoldAccent}"
                                       FontSize="34" FontAttributes="Bold"
                                       LineBreakMode="NoWrap"/>
                                <Label Text="{i18n:Translate Sec}"
                                       TextColor="{StaticResource GreenCardText}"
                                       FontSize="10" FontAttributes="Bold"
                                       CharacterSpacing="1"/>
                            </VerticalStackLayout>

                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  DAILY TIMES HEADER  -->
            <!-- ═══════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,Auto" Margin="2,0,2,0">
                <Label Grid.Column="0"
                       Text="{i18n:Translate DailyTimes}"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="18" FontAttributes="Bold"
                       VerticalOptions="Center"/>

            </Grid>

            <!-- ═══════════════════════════════════════════ -->
            <!--  PRAYER ROWS  -->
            <!-- ═══════════════════════════════════════════ -->

            <!-- Fajr -->
            <Border x:Name="FajrRow" BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="14,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border x:Name="FajrIcon" Grid.Column="0" BackgroundColor="{StaticResource IconBg}"
                            StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🌙" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label x:Name="FajrNameLbl" Grid.Column="1" Text="{i18n:Translate Prayer_Fajr}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label x:Name="FajrTime" Grid.Column="2" Text="—"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Sunrise (time marker, never highlighted) -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="14,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border Grid.Column="0" BackgroundColor="{StaticResource IconBg}"
                            StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🌄" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Grid.Column="1" Text="{i18n:Translate Prayer_Sunrise}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label x:Name="SunriseTime" Grid.Column="2" Text="—"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Dhuhr -->
            <Border x:Name="DhuhrRow" BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="14,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border x:Name="DhuhrIcon" Grid.Column="0" BackgroundColor="{StaticResource IconBg}"
                            StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="☀️" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label x:Name="DhuhrNameLbl" Grid.Column="1" Text="{i18n:Translate Prayer_Dhuhr}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label x:Name="DhuhrTime" Grid.Column="2" Text="—"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Asr -->
            <Border x:Name="AsrRow" BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="14,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border x:Name="AsrIcon" Grid.Column="0" BackgroundColor="{StaticResource IconBg}"
                            StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🌤" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label x:Name="AsrNameLbl" Grid.Column="1" Text="{i18n:Translate Prayer_Asr}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label x:Name="AsrTime" Grid.Column="2" Text="—"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Maghrib -->
            <Border x:Name="MaghribRow" BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="14,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border x:Name="MaghribIcon" Grid.Column="0" BackgroundColor="{StaticResource IconBg}"
                            StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🌅" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label x:Name="MaghribNameLbl" Grid.Column="1" Text="{i18n:Translate Prayer_Maghrib}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label x:Name="MaghribTime" Grid.Column="2" Text="—"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Isha -->
            <Border x:Name="IshaRow" BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="14,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border x:Name="IshaIcon" Grid.Column="0" BackgroundColor="{StaticResource IconBg}"
                            StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🌙" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label x:Name="IshaNameLbl" Grid.Column="1" Text="{i18n:Translate Prayer_Isha}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label x:Name="IshaTime" Grid.Column="2" Text="—"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="14" VerticalOptions="Center"/>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
