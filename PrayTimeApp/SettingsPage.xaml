<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:Nooria.Extensions"
             x:Class="Nooria.SettingsPage"
             BackgroundColor="{StaticResource AppBg}">

    <ContentPage.Resources>

        <!-- Gold toggle (green track, gold thumb) -->
        <Style x:Key="GoldToggle" TargetType="Switch">
            <Setter Property="OnColor"    Value="#2A6B45"/>
            <Setter Property="ThumbColor" Value="{StaticResource GoldAccent}"/>
        </Style>

        <!-- Stepper − button: outlined gold border -->
        <Style x:Key="StepDec" TargetType="Border">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="Stroke"          Value="{StaticResource GoldAccent}"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="WidthRequest"    Value="34"/>
            <Setter Property="HeightRequest"   Value="34"/>
            <Setter Property="StrokeShape">
                <Setter.Value><RoundRectangle CornerRadius="10"/></Setter.Value>
            </Setter>
        </Style>

        <!-- Stepper + button: solid gold fill -->
        <Style x:Key="StepInc" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{StaticResource GoldAccent}"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Setter Property="WidthRequest"    Value="34"/>
            <Setter Property="HeightRequest"   Value="34"/>
            <Setter Property="StrokeShape">
                <Setter.Value><RoundRectangle CornerRadius="10"/></Setter.Value>
            </Setter>
        </Style>

    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,32" Spacing="14">

            <!-- ═══════════════════════════════════════════ -->
            <!--  HEADER                                     -->
            <!-- ═══════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <Label Grid.Column="0"
                       Text="{i18n:Translate Settings}"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       VerticalOptions="Center"/>
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource CardBg}"
                        StrokeThickness="0"
                        WidthRequest="40" HeightRequest="40"
                        VerticalOptions="Center">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Label Text="?" FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════ -->
            <!--  APP LANGUAGE CARD                          -->
            <!-- ═══════════════════════════════════════════ -->
            <Border BackgroundColor="{StaticResource GreenCard}"
                    Stroke="{StaticResource GreenCardBorder}"
                    StrokeThickness="1.5"
                    Padding="16,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource GoldBadgeBg}"
                                StrokeThickness="0" WidthRequest="42" HeightRequest="42">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Label Text="🌐" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="{i18n:Translate AppLanguage}"
                                   TextColor="{StaticResource GoldAccent}"
                                   FontSize="15" FontAttributes="Bold"/>
                            <Label Text="{i18n:Translate SelectLanguage}"
                                   TextColor="{StaticResource GreenCardText}"
                                   FontSize="12"/>
                        </VerticalStackLayout>

                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource CardBg}"
                                StrokeThickness="0" Padding="12,6" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Label x:Name="LanguageBadgeLabel"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="13" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <Border BackgroundColor="{StaticResource GoldAccent}"
                            StrokeThickness="0" Padding="0,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChangeLanguageTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="{i18n:Translate Change}"
                               TextColor="#0D1623" FontSize="14" FontAttributes="Bold"
                               CharacterSpacing="1.5" HorizontalOptions="Center"/>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  SECTION LABEL: ALARMS                      -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="{i18n:Translate NotificationsAndPrefs}"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="11" FontAttributes="Bold"
                   CharacterSpacing="1.2"
                   Margin="2,6,0,0"/>

            <!-- ─────────────────────────────────────────── -->
            <!--  CARD 1 · BEFORE PRAYER TIME                -->
            <!-- ─────────────────────────────────────────── -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="16,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- Header row -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource GoldBadgeBg}"
                                StrokeThickness="0" WidthRequest="42" HeightRequest="42">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Label Text="🔔" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="{i18n:Translate Sett_Before}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="15" FontAttributes="Bold"/>
                            <Label x:Name="BeforePrayerSummary" Text="Off"
                                   TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                        </VerticalStackLayout>

                        <Switch x:Name="BeforePrayerSwitch" Grid.Column="2"
                                Style="{StaticResource GoldToggle}"
                                VerticalOptions="Center"
                                Toggled="OnBeforePrayerToggled"/>
                    </Grid>

                    <!-- Expandable detail -->
                    <VerticalStackLayout x:Name="BeforePrayerDetail" IsVisible="False" Spacing="0">

                        <BoxView HeightRequest="1" Color="{StaticResource GreenCardBorder}" Margin="0,12,0,0"/>

                        <!-- Hours + Minutes in one row -->
                        <Grid ColumnDefinitions="*,*" Padding="0,12" ColumnSpacing="8">
                            <!-- Hours -->
                            <Grid Grid.Column="0" ColumnDefinitions="34,*,34" ColumnSpacing="6" VerticalOptions="Center">
                                <Border Grid.Column="0" Style="{StaticResource StepDec}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeforePrayerHDec"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="−" TextColor="{StaticResource GoldAccent}"
                                           FontSize="18" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" x:Name="BeforePrayerHLabel" Text="0 h"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                <Border Grid.Column="2" Style="{StaticResource StepInc}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeforePrayerHInc"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="+" TextColor="#0D1623"
                                           FontSize="18" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <!-- Minutes -->
                            <Grid Grid.Column="1" ColumnDefinitions="34,*,34" ColumnSpacing="6" VerticalOptions="Center">
                                <Border Grid.Column="0" Style="{StaticResource StepDec}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeforePrayerMDec"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="−" TextColor="{StaticResource GoldAccent}"
                                           FontSize="18" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" x:Name="BeforePrayerMLabel" Text="30 min"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                <Border Grid.Column="2" Style="{StaticResource StepInc}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBeforePrayerMInc"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="+" TextColor="#0D1623"
                                           FontSize="18" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource GreenCardBorder}"/>

                        <!-- Tone selector -->
                        <Grid ColumnDefinitions="*,Auto" Padding="0,14" ColumnSpacing="12">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBeforePrayerToneTapped"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="{i18n:Translate Sett_SoundAdhan}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14" VerticalOptions="Center"/>
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                                <Label x:Name="BeforePrayerToneLabel" Text="Default"
                                       TextColor="{StaticResource GoldAccent}"
                                       FontSize="13" FontAttributes="Bold"/>
                                <Label Text="›" TextColor="{StaticResource TextSecondary}" FontSize="20"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <Label Text="{i18n:Translate AppliesToAll}" TextColor="#888" FontSize="11" Margin="0,4,0,0"/>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ─────────────────────────────────────────── -->
            <!--  CARD 2 · ON PRAYER TIME                    -->
            <!-- ─────────────────────────────────────────── -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="16,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- Header row -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource GoldBadgeBg}"
                                StrokeThickness="0" WidthRequest="42" HeightRequest="42">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Label Text="🕌" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="{i18n:Translate Sett_On}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="15" FontAttributes="Bold"/>
                            <Label x:Name="OnPrayerSummary" Text="Off"
                                   TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                        </VerticalStackLayout>

                        <Switch x:Name="OnPrayerSwitch" Grid.Column="2"
                                Style="{StaticResource GoldToggle}"
                                VerticalOptions="Center"
                                Toggled="OnOnPrayerToggled"/>
                    </Grid>

                    <!-- Expandable detail (tone only — no offset) -->
                    <VerticalStackLayout x:Name="OnPrayerDetail" IsVisible="False" Spacing="0">

                        <BoxView HeightRequest="1" Color="{StaticResource GreenCardBorder}" Margin="0,12,0,0"/>

                        <!-- Tone selector -->
                        <Grid ColumnDefinitions="*,Auto" Padding="0,14" ColumnSpacing="12">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOnPrayerToneTapped"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="{i18n:Translate Sett_SoundAdhan}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14" VerticalOptions="Center"/>
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                                <Label x:Name="OnPrayerToneLabel" Text="Default"
                                       TextColor="{StaticResource GoldAccent}"
                                       FontSize="13" FontAttributes="Bold"/>
                                <Label Text="›" TextColor="{StaticResource TextSecondary}" FontSize="20"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <Label Text="{i18n:Translate AppliesToAll}" TextColor="#888" FontSize="11" Margin="0,4,0,0"/>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ─────────────────────────────────────────── -->
            <!--  CARD 3 · PRAYER TIME ENDS IN               -->
            <!-- ─────────────────────────────────────────── -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="16,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- Header row -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource GoldBadgeBg}"
                                StrokeThickness="0" WidthRequest="42" HeightRequest="42">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Label Text="⏰" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="{i18n:Translate Sett_Ends}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="15" FontAttributes="Bold"/>
                            <Label x:Name="EndsInSummary" Text="Off"
                                   TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                        </VerticalStackLayout>

                        <Switch x:Name="EndsInSwitch" Grid.Column="2"
                                Style="{StaticResource GoldToggle}"
                                VerticalOptions="Center"
                                Toggled="OnEndsInToggled"/>
                    </Grid>

                    <!-- Expandable detail -->
                    <VerticalStackLayout x:Name="EndsInDetail" IsVisible="False" Spacing="0">

                        <BoxView HeightRequest="1" Color="{StaticResource GreenCardBorder}" Margin="0,12,0,0"/>

                        <!-- Hours + Minutes in one row -->
                        <Grid ColumnDefinitions="*,*" Padding="0,12" ColumnSpacing="8">
                            <!-- Hours -->
                            <Grid Grid.Column="0" ColumnDefinitions="34,*,34" ColumnSpacing="6" VerticalOptions="Center">
                                <Border Grid.Column="0" Style="{StaticResource StepDec}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnEndsInHDec"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="−" TextColor="{StaticResource GoldAccent}"
                                           FontSize="18" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" x:Name="EndsInHLabel" Text="0 h"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                <Border Grid.Column="2" Style="{StaticResource StepInc}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnEndsInHInc"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="+" TextColor="#0D1623"
                                           FontSize="18" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                            <!-- Minutes -->
                            <Grid Grid.Column="1" ColumnDefinitions="34,*,34" ColumnSpacing="6" VerticalOptions="Center">
                                <Border Grid.Column="0" Style="{StaticResource StepDec}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnEndsInMDec"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="−" TextColor="{StaticResource GoldAccent}"
                                           FontSize="18" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" x:Name="EndsInMLabel" Text="30 min"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="14" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                <Border Grid.Column="2" Style="{StaticResource StepInc}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnEndsInMInc"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="+" TextColor="#0D1623"
                                           FontSize="18" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource GreenCardBorder}"/>

                        <!-- Tone selector -->
                        <Grid ColumnDefinitions="*,Auto" Padding="0,14" ColumnSpacing="12">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEndsInToneTapped"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="{i18n:Translate Sett_SoundAdhan}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14" VerticalOptions="Center"/>
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                                <Label x:Name="EndsInToneLabel" Text="Default"
                                       TextColor="{StaticResource GoldAccent}"
                                       FontSize="13" FontAttributes="Bold"/>
                                <Label Text="›" TextColor="{StaticResource TextSecondary}" FontSize="20"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <Label Text="{i18n:Translate AppliesToAll}" TextColor="#888" FontSize="11" Margin="0,4,0,0"/>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  LOCATION THRESHOLD                         -->
            <!-- ═══════════════════════════════════════════ -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="16,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource GoldBadgeBg}"
                            StrokeThickness="0" WidthRequest="42" HeightRequest="42">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="📍" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                        <Label Text="{i18n:Translate LocationThreshold}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="15" FontAttributes="Bold"/>
                        <Label Text="{i18n:Translate LocationThresholdDesc}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="11" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="6"
                                         HorizontalOptions="End" VerticalOptions="Center">
                        <Label x:Name="ThresholdValueLabel"
                               Text="30 km"
                               TextColor="{StaticResource GoldAccent}"
                               FontSize="15" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource CardBg}"
                                    Stroke="{StaticResource GoldAccent}"
                                    StrokeThickness="1"
                                    WidthRequest="34" HeightRequest="34">
                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnThresholdDecrease"/>
                                </Border.GestureRecognizers>
                                <Label Text="−" TextColor="{StaticResource GoldAccent}"
                                       FontSize="18" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource GoldAccent}"
                                    StrokeThickness="0"
                                    WidthRequest="34" HeightRequest="34">
                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnThresholdIncrease"/>
                                </Border.GestureRecognizers>
                                <Label Text="+" TextColor="#0D1623"
                                       FontSize="18" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  SECTION: CALCULATION METHOD                -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="{i18n:Translate CalculationMethod}"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="11" FontAttributes="Bold"
                   CharacterSpacing="1.2"
                   Margin="2,6,0,0"/>

            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="16,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" Padding="0,14">
                    <Border Grid.Column="0" BackgroundColor="{StaticResource GoldBadgeBg}"
                            StrokeThickness="0" WidthRequest="38" HeightRequest="38">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Label Text="⚙️" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                        <Label Text="{i18n:Translate FajrIshaMethod}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="15" FontAttributes="Bold"/>
                        <Label Text="{i18n:Translate MuslimWorldLeague}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="11" FontAttributes="Bold" CharacterSpacing="0.5"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  TEST BUTTONS                               -->
            <!-- ═══════════════════════════════════════════ -->

            <!-- Play / Pause sound test -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="14,10">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource GoldBadgeBg}"
                            StrokeThickness="0" WidthRequest="42" HeightRequest="42">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="🔊" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSelectTestToneTapped"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <Label Text="{i18n:Translate Sett_PlayNow}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="15" FontAttributes="Bold"/>
                        <HorizontalStackLayout Spacing="4">
                            <Label x:Name="TestToneLabel" Text="Default"
                                   TextColor="{StaticResource GoldAccent}" FontSize="12"/>
                            <Label Text="›" TextColor="{StaticResource TextSecondary}"
                                   FontSize="14" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Border x:Name="PlayStopBtn" Grid.Column="2"
                            BackgroundColor="{StaticResource GoldAccent}"
                            StrokeThickness="0" WidthRequest="42" HeightRequest="42">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPlayStopTapped"/>
                        </Border.GestureRecognizers>
                        <Label x:Name="PlayStopIcon" Text="▶"
                               TextColor="#0D1623" FontSize="16" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                </Grid>
            </Border>


        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
