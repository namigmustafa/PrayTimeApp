<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:Nooria.Extensions"
             x:Class="Nooria.CalcMethodConfigPage"
             BackgroundColor="{StaticResource AppBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="16,50,16,12" BackgroundColor="{StaticResource AppBg}">
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource CardBg}"
                    Stroke="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    WidthRequest="36" HeightRequest="36">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Border.GestureRecognizers>
                <Label Text="‹" TextColor="{StaticResource GoldAccent}" FontSize="22"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1"
                   Text="{i18n:Translate CalcConfig_Title}"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   Margin="12,0,0,0"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="10" Padding="16,4">

                <!-- Shafaq -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{i18n:Translate CalcConfig_Shafaq}"
                               TextColor="{StaticResource GoldAccent}" FontSize="13" FontAttributes="Bold"/>
                        <Label Text="{i18n:Translate CalcConfig_ShafaqDesc}"
                               TextColor="#999" FontSize="11"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnShafaqTapped"/>
                            </Grid.GestureRecognizers>
                            <Label x:Name="ShafaqValueLabel" Grid.Column="0" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="›" TextColor="{StaticResource GoldAccent}" FontSize="20" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Tune -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{i18n:Translate CalcConfig_Tune}"
                               TextColor="{StaticResource GoldAccent}" FontSize="13" FontAttributes="Bold"/>
                        <Label Text="{i18n:Translate CalcConfig_TuneDesc}"
                               TextColor="#999" FontSize="11"/>
                        <Entry x:Name="TuneEntry"
                               Placeholder="0,0,0,0,0,0,0,0,0"
                               PlaceholderColor="#666"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               FontSize="15"
                               Keyboard="Text"
                               Margin="0,8,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- School -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{i18n:Translate CalcConfig_School}"
                               TextColor="{StaticResource GoldAccent}" FontSize="13" FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSchoolTapped"/>
                            </Grid.GestureRecognizers>
                            <Label x:Name="SchoolValueLabel" Grid.Column="0" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="›" TextColor="{StaticResource GoldAccent}" FontSize="20" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Midnight -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{i18n:Translate CalcConfig_Midnight}"
                               TextColor="{StaticResource GoldAccent}" FontSize="13" FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMidnightTapped"/>
                            </Grid.GestureRecognizers>
                            <Label x:Name="MidnightValueLabel" Grid.Column="0" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="›" TextColor="{StaticResource GoldAccent}" FontSize="20" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- LatAdj -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{i18n:Translate CalcConfig_LatAdj}"
                               TextColor="{StaticResource GoldAccent}" FontSize="13" FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLatAdjTapped"/>
                            </Grid.GestureRecognizers>
                            <Label x:Name="LatAdjValueLabel" Grid.Column="0" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="›" TextColor="{StaticResource GoldAccent}" FontSize="20" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Calendar -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{i18n:Translate CalcConfig_Calendar}"
                               TextColor="{StaticResource GoldAccent}" FontSize="13" FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCalendarTapped"/>
                            </Grid.GestureRecognizers>
                            <Label x:Name="CalendarValueLabel" Grid.Column="0" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="›" TextColor="{StaticResource GoldAccent}" FontSize="20" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Padding="16,10,16,32">
            <!-- Apply -->
            <Border BackgroundColor="{StaticResource GoldAccent}"
                    Stroke="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnApplyTapped"/>
                </Border.GestureRecognizers>
                <Label Text="{i18n:Translate CalcConfig_Apply}"
                       TextColor="#1a1a1a"
                       FontSize="15"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,14"/>
            </Border>
            <!-- Reset -->
            <Border BackgroundColor="Transparent"
                    Stroke="{StaticResource GoldAccent}"
                    StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnResetTapped"/>
                </Border.GestureRecognizers>
                <Label Text="{i18n:Translate CalcConfig_Reset}"
                       TextColor="{StaticResource GoldAccent}"
                       FontSize="15"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,14"/>
            </Border>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
