                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFajrMinus"/>
                            </Border.GestureRecognizers>
                            <Label Text="−" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="FajrValue" Grid.Column="2" Text="0"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               WidthRequest="36" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                        <Border Grid.Column="3" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFajrPlus"/>
                            </Border.GestureRecognizers>
                            <Label Text="+" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Sunrise -->
