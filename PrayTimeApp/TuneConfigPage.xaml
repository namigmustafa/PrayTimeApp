                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSunriseMinus"/>
                            </Border.GestureRecognizers>
                            <Label Text="−" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
