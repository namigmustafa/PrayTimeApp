                        </Border>
                        <Label x:Name="DhuhrValue" Grid.Column="2" Text="0"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               WidthRequest="36" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                        <Border Grid.Column="3" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDhuhrPlus"/>
                            </Border.GestureRecognizers>
                            <Label Text="+" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Asr -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <Label Grid.Column="0" Text="Asr" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAsrMinus"/>
                            </Border.GestureRecognizers>
                            <Label Text="−" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="AsrValue" Grid.Column="2" Text="0"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               WidthRequest="36" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                        <Border Grid.Column="3" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAsrPlus"/>
                            </Border.GestureRecognizers>
                            <Label Text="+" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Maghrib -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <Label Grid.Column="0" Text="Maghrib" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMaghribMinus"/>
                            </Border.GestureRecognizers>
                            <Label Text="−" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="MaghribValue" Grid.Column="2" Text="0"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               WidthRequest="36" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                        <Border Grid.Column="3" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMaghribPlus"/>
                            </Border.GestureRecognizers>
                            <Label Text="+" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Sunset -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <Label Grid.Column="0" Text="Sunset" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSunsetMinus"/>
                            </Border.GestureRecognizers>
                            <Label Text="−" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="SunsetValue" Grid.Column="2" Text="0"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               WidthRequest="36" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                        <Border Grid.Column="3" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSunsetPlus"/>
                            </Border.GestureRecognizers>
                            <Label Text="+" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Isha -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <Label Grid.Column="0" Text="Isha" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnIshaMinus"/>
                            </Border.GestureRecognizers>
                            <Label Text="−" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="IshaValue" Grid.Column="2" Text="0"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               WidthRequest="36" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                        <Border Grid.Column="3" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnIshaPlus"/>
                            </Border.GestureRecognizers>
                            <Label Text="+" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Midnight -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <Label Grid.Column="0" Text="Midnight" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMidnightMinus"/>
                            </Border.GestureRecognizers>
                            <Label Text="−" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="MidnightValue" Grid.Column="2" Text="0"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               WidthRequest="36" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                        <Border Grid.Column="3" BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                WidthRequest="38" HeightRequest="38" Margin="4,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMidnightPlus"/>
                            </Border.GestureRecognizers>
                            <Label Text="+" TextColor="{StaticResource GoldAccent}" FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Padding="16,10,16,32">
            <Border BackgroundColor="{StaticResource GoldAccent}"
                    Stroke="Transparent" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnApplyTapped"/>
                </Border.GestureRecognizers>
                <Label Text="Apply"
                       TextColor="#1a1a1a" FontSize="15" FontAttributes="Bold"
                       HorizontalOptions="Center" Margin="0,14"/>
            </Border>
            <Border BackgroundColor="Transparent"
                    Stroke="{StaticResource GoldAccent}" StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnResetTapped"/>
                </Border.GestureRecognizers>
                <Label Text="Reset to Defaults"
                       TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                       HorizontalOptions="Center" Margin="0,14"/>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
