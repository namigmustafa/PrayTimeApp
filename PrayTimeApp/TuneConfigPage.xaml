<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Nooria.TuneConfigPage"
             BackgroundColor="{StaticResource AppBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="16,50,16,12" BackgroundColor="{StaticResource AppBg}">
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource CardBg}"
                    Stroke="Transparent" StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    WidthRequest="36" HeightRequest="36">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Border.GestureRecognizers>
                <Label Text="‹" TextColor="{StaticResource GoldAccent}" FontSize="22"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1"
                   Text="Tune (Minutes Adjustment)"
                   TextColor="White" FontSize="18" FontAttributes="Bold"
                   VerticalOptions="Center" Margin="12,0,0,0"/>
        </Grid>

        <!-- Inputs -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="10" Padding="16,4">

                <!-- Description -->
                <Label Text="Adjust each prayer time by adding or subtracting minutes. Use negative values to subtract."
                       TextColor="#999" FontSize="12" Margin="0,0,0,4"/>

                <!-- Imsak -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Imsak" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="ImsakEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Fajr -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Fajr" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="FajrEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Sunrise -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Sunrise" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="SunriseEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Dhuhr -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Dhuhr" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="DhuhrEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Asr -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Asr" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="AsrEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Maghrib -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Maghrib" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="MaghribEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Sunset -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Sunset" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="SunsetEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Isha -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Isha" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="IshaEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Midnight -->
                <Border BackgroundColor="{StaticResource CardBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Midnight" TextColor="White" FontSize="15" VerticalOptions="Center"/>
                        <Entry x:Name="MidnightTuneEntry" Grid.Column="1"
                               TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                               BackgroundColor="Transparent" Keyboard="Numeric"
                               HorizontalOptions="End" WidthRequest="70" HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Padding="16,10,16,32">
            <Border BackgroundColor="{StaticResource GoldAccent}"
                    Stroke="Transparent" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnApplyTapped"/>
                </Border.GestureRecognizers>
                <Label Text="Apply"
                       TextColor="#1a1a1a" FontSize="15" FontAttributes="Bold"
                       HorizontalOptions="Center" Margin="0,14"/>
            </Border>
            <Border BackgroundColor="Transparent"
                    Stroke="{StaticResource GoldAccent}" StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnResetTapped"/>
                </Border.GestureRecognizers>
                <Label Text="Reset to Defaults"
                       TextColor="{StaticResource GoldAccent}" FontSize="15" FontAttributes="Bold"
                       HorizontalOptions="Center" Margin="0,14"/>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
