<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:Nooria.Extensions"
             x:Class="Nooria.MonthlyPage"
             BackgroundColor="{StaticResource AppBg}">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,20" Spacing="14">

            <!-- ═══════════════════════════════════════════ -->
            <!--  HEADER (always visible)                    -->
            <!-- ═══════════════════════════════════════════ -->
            <VerticalStackLayout Spacing="6" Margin="0,8,0,0">
                <HorizontalStackLayout Spacing="4">
                    <Label Text="📍" FontSize="13" TextColor="{StaticResource GoldAccent}"
                           VerticalOptions="Center"/>
                    <Label x:Name="LocationLabel"
                           Text="..." FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource GoldAccent}"
                           CharacterSpacing="1.2" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="{i18n:Translate MonthlySchedule}"
                       FontSize="26" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"/>
            </VerticalStackLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!--  SKELETON VIEW (visible while loading)      -->
            <!-- ═══════════════════════════════════════════ -->
            <VerticalStackLayout x:Name="SkeletonView" Spacing="14">

                <!-- Month card placeholder -->
                <Border HeightRequest="66" StrokeThickness="0" BackgroundColor="#1A2A3A">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                </Border>

                <!-- Table card placeholder -->
                <Border StrokeThickness="0" BackgroundColor="#1A2A3A" Padding="16,14">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <!-- Header row placeholder -->
                        <Border HeightRequest="18" StrokeThickness="0" BackgroundColor="#243545">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        </Border>
                        <BoxView HeightRequest="1" Color="#243545"/>
                        <!-- 7 row placeholders -->
                        <Border HeightRequest="34" StrokeThickness="0" BackgroundColor="#243545">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        </Border>
                        <Border HeightRequest="34" StrokeThickness="0" BackgroundColor="#243545">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        </Border>
                        <Border HeightRequest="34" StrokeThickness="0" BackgroundColor="#243545">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        </Border>
                        <Border HeightRequest="34" StrokeThickness="0" BackgroundColor="#243545">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        </Border>
                        <Border HeightRequest="34" StrokeThickness="0" BackgroundColor="#243545">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        </Border>
                        <Border HeightRequest="34" StrokeThickness="0" BackgroundColor="#243545">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        </Border>
                        <Border HeightRequest="34" StrokeThickness="0" BackgroundColor="#243545">
                            <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        </Border>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!--  MAIN CONTENT (hidden until loaded)         -->
            <!-- ═══════════════════════════════════════════ -->
            <VerticalStackLayout x:Name="MainContent" Spacing="14" IsVisible="false">

            <!-- ═══════════════════════════════════════════ -->
            <!--  MONTH CARD                                 -->
            <!-- ═══════════════════════════════════════════ -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0"
                    Padding="18,14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="4">
                    <Label x:Name="MonthYearLabel"
                           Text="…"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="15" FontAttributes="Bold"/>
                    <Label x:Name="HijriMonthLabel"
                           Text="…"
                           TextColor="{StaticResource GoldAccent}"
                           FontSize="13" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  PRAYER TIMES TABLE                         -->
            <!-- ═══════════════════════════════════════════ -->
            <Border BackgroundColor="{StaticResource GreenCard}"
                    StrokeThickness="0"
                    Padding="16,14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- Table header row -->
                    <Grid ColumnDefinitions="50,*,*,*,*,*,*" Padding="0,0,0,10">
                        <Label Grid.Column="0" Text="{i18n:Translate Date}"
                               TextColor="{StaticResource GreenCardText}"
                               FontSize="10" FontAttributes="Bold" CharacterSpacing="0.5"/>
                        <Label Grid.Column="1" Text="{i18n:Translate Prayer_Fajr}"
                               TextColor="{StaticResource GreenCardText}"
                               FontSize="10" FontAttributes="Bold" CharacterSpacing="0.5"
                               HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="2" Text="{i18n:Translate Prayer_Sunrise}"
                               TextColor="{StaticResource GreenCardText}"
                               FontSize="10" FontAttributes="Bold" CharacterSpacing="0.5"
                               HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="3" Text="{i18n:Translate Prayer_Dhuhr}"
                               TextColor="{StaticResource GreenCardText}"
                               FontSize="10" FontAttributes="Bold" CharacterSpacing="0.5"
                               HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="4" Text="{i18n:Translate Prayer_Asr}"
                               TextColor="{StaticResource GreenCardText}"
                               FontSize="10" FontAttributes="Bold" CharacterSpacing="0.5"
                               HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="5" Text="{i18n:Translate Prayer_Maghrib}"
                               TextColor="{StaticResource GoldAccent}"
                               FontSize="9" FontAttributes="Bold" CharacterSpacing="0.5"
                               HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="6" Text="{i18n:Translate Prayer_Isha}"
                               TextColor="{StaticResource GreenCardText}"
                               FontSize="10" FontAttributes="Bold" CharacterSpacing="0.5"
                               HorizontalTextAlignment="Center"/>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="{StaticResource GreenCardBorder}"/>

                    <!-- Dynamic rows populated from code-behind -->
                    <VerticalStackLayout x:Name="PrayerTableRows" Spacing="0"/>

                </VerticalStackLayout>
            </Border>

            </VerticalStackLayout><!-- end MainContent -->

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
