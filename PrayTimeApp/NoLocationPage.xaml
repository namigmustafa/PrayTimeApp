<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Nooria.NoLocationPage"
             BackgroundColor="{StaticResource AppBg}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" Padding="24,52,24,24">

        <!-- ── Header: icon + description + use location + divider + search ── -->
        <VerticalStackLayout Grid.Row="0" Spacing="16">

            <!-- Language chip — top right -->
            <Border HorizontalOptions="End"
                    BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="10,6">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChangeLanguageTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="5">
                    <Label Text="🌐" FontSize="13" VerticalOptions="Center"/>
                    <Label x:Name="LanguageBadgeLabel"
                           FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           VerticalOptions="Center"/>
                    <Label Text="›" FontSize="16"
                           TextColor="{StaticResource TextSecondary}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Icon + texts -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="📍" FontSize="56" HorizontalOptions="Center"/>
                <Label x:Name="TitleLabel"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center"/>
                <Label x:Name="DescLabel"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center"
                       Margin="10,0"/>
            </VerticalStackLayout>

            <!-- Use current location -->
            <Border BackgroundColor="{StaticResource GoldAccent}"
                    StrokeThickness="0" Padding="16,14">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnUseCurrentLocationTapped"/>
                </Border.GestureRecognizers>
                <Label x:Name="UseLocationLabel"
                       TextColor="#0D1623" FontSize="15" FontAttributes="Bold"
                       HorizontalOptions="Center"/>
            </Border>

            <!-- OR divider -->
            <Grid ColumnDefinitions="*,Auto,*" VerticalOptions="Center">
                <BoxView Grid.Column="0" HeightRequest="1"
                         Color="{StaticResource GreenCardBorder}" VerticalOptions="Center"/>
                <Label x:Name="OrLabel" Grid.Column="1"
                       TextColor="{StaticResource TextSecondary}" FontSize="13"
                       VerticalOptions="Center"/>
                <BoxView Grid.Column="2" HeightRequest="1"
                         Color="{StaticResource GreenCardBorder}" VerticalOptions="Center"/>
            </Grid>

            <!-- Search bar -->
            <Border BackgroundColor="{StaticResource CardBg}"
                    StrokeThickness="0" Padding="14,12">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Grid.Column="0" Text="🔍" FontSize="16"
                           TextColor="{StaticResource TextSecondary}" VerticalOptions="Center"/>
                    <Entry x:Name="SearchEntry"
                           Grid.Column="1"
                           PlaceholderColor="{StaticResource TextSecondary}"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="Transparent"
                           ReturnType="Search"
                           TextChanged="OnSearchTextChanged"/>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <!-- ── Results area (Row 1 = * → CollectionView is constrained → scrolls) ── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,8,0,0">

            <!-- Loading / no-results (Row 0, Auto) -->
            <ActivityIndicator Grid.Row="0"
                               x:Name="LoadingIndicator"
                               IsRunning="False" IsVisible="False"
                               Color="{StaticResource GoldAccent}"
                               HorizontalOptions="Center"
                               Margin="0,12,0,0"/>

            <Label Grid.Row="0"
                   x:Name="NoResultsLabel"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="14" IsVisible="False"
                   HorizontalOptions="Center"
                   Margin="0,12,0,0"/>

            <!-- Results list (Row 1 = * → scrollable) -->
            <CollectionView Grid.Row="1"
                            x:Name="ResultsList"
                            IsVisible="False"
                            SelectionMode="Single"
                            SelectionChanged="OnCitySelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{StaticResource CardBg}"
                                StrokeThickness="0"
                                Padding="16,14"
                                Margin="0,0,0,8">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="🌆" FontSize="18" VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding City}"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="15" FontAttributes="Bold"/>
                                    <Label Text="{Binding Country}"
                                           TextColor="{StaticResource TextSecondary}"
                                           FontSize="12"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

    </Grid>

</ContentPage>
